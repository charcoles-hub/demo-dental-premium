<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Reveals
  const revelados = document.querySelectorAll("[data-reveal]");
  if (reduceMotion || !("IntersectionObserver" in window)) {
    revelados.forEach((el) => el.classList.add("in"));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.18, rootMargin: "0px 0px -8% 0px" }
    );
    revelados.forEach((el) => io.observe(el));
  }

  // Hilo dental: se dibuja al entrar en pantalla
  const hilos = document.querySelectorAll(".hilo");
  if (reduceMotion || !("IntersectionObserver" in window)) {
    hilos.forEach((h) => h.classList.add("dibujado"));
  } else {
    const ioHilo = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("dibujado");
            ioHilo.unobserve(e.target);
          }
        }
      },
      { threshold: 0.5 }
    );
    hilos.forEach((h) => ioHilo.observe(h));
  }

  // Contadores
  const formatea = (el: Element, valor: number) => {
    const d = (el as HTMLElement).dataset;
    const texto = d.miles !== undefined ? valor.toLocaleString("es-ES") : String(valor);
    el.textContent = `${d.prefijo ?? ""}${texto}${d.sufijo ?? ""}`;
  };
  const contadores = document.querySelectorAll("[data-count]");
  if (reduceMotion || !("IntersectionObserver" in window)) {
    contadores.forEach((el) => formatea(el, Number((el as HTMLElement).dataset.count)));
  } else {
    const ioCuenta = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          ioCuenta.unobserve(e.target);
          const el = e.target;
          const fin = Number((el as HTMLElement).dataset.count);
          const dur = 1400;
          const t0 = performance.now();
          const paso = (t: number) => {
            const p = Math.min((t - t0) / dur, 1);
            const suave = 1 - Math.pow(1 - p, 3);
            formatea(el, Math.round(fin * suave));
            if (p < 1) requestAnimationFrame(paso);
          };
          requestAnimationFrame(paso);
        }
      },
      { threshold: 0.6 }
    );
    contadores.forEach((el) => ioCuenta.observe(el));
  }

  // Línea de progreso de "primera visita" + pasos activos
  const pasos = document.querySelector(".pasos") as HTMLElement | null;
  if (pasos && !reduceMotion) {
    let pendiente = false;
    const actualiza = () => {
      pendiente = false;
      const r = pasos.getBoundingClientRect();
      const p = Math.min(Math.max((window.innerHeight * 0.72 - r.top) / r.height, 0), 1);
      pasos.style.setProperty("--p", p.toFixed(3));
      const items = pasos.querySelectorAll(".paso");
      items.forEach((item, i) => {
        item.classList.toggle("activo", p >= (i + 0.5) / items.length);
      });
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!pendiente) {
          pendiente = true;
          requestAnimationFrame(actualiza);
        }
      },
      { passive: true }
    );
    actualiza();
  } else if (pasos) {
    pasos.style.setProperty("--p", "1");
    pasos.querySelectorAll(".paso").forEach((i) => i.classList.add("activo"));
  }

  // Topbar compacta al hacer scroll
  const topbar = document.getElementById("topbar");
  if (topbar) {
    const marca = () => topbar.classList.toggle("compacta", window.scrollY > 24);
    window.addEventListener("scroll", marca, { passive: true });
    marca();
  }
</script>
