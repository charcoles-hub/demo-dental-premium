---
import Layout from "../../layouts/Layout.astro";
import { leads, type Lead } from "../../data/leads";

export function getStaticPaths() {
  return leads.map((lead) => ({ params: { slug: lead.slug }, props: { lead } }));
}

const { lead } = Astro.props as { lead: Lead };

const telBonito = lead.telefono.replace(
  /^(\d{3})(\d{2})(\d{2})(\d{2})$/,
  "$1 $2 $3 $4"
);
const telHref = `tel:+34${lead.telefono}`;

const title = `${lead.negocio} · Clínica dental en ${lead.ciudad}`;
const description = `Implantes, ortodoncia invisible y estética dental en ${lead.ciudad}. Primera visita con radiografía gratis. Llama al ${telBonito}.`;
---

<Layout title={title} description={description}>
  <header class="topbar" id="topbar">
    <a class="marca" href="#inicio" aria-label={`${lead.negocio}, volver arriba`}>
      <svg class="marca-diente" viewBox="0 0 48 48" aria-hidden="true">
        <path
          d="M24 6c-8.4 0-12.6 5.5-11.5 13.2.6 4.5 2.7 8.4 3.7 13.9.5 3.3 2.3 5.3 4 5.3 1.9 0 2.2-3.3 2.7-6.1.4-2.5 1.9-2.5 2.3 0 .5 2.8.8 6.1 2.7 6.1 1.7 0 3.5-2 4-5.3 1-5.5 3.1-9.4 3.7-13.9C36.6 11.5 32.4 6 24 6z"
          fill="currentColor"
        />
        <circle cx="33" cy="12" r="3" class="marca-chispa" />
      </svg>
      <span>{lead.negocio}</span>
    </a>
    <a class="tel-chip" href={telHref}>
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M6.6 3.3 8.9 5.6c.6.6.7 1.6.1 2.3L7.8 9.3c1 2.3 2.7 4 5 5l1.4-1.2c.7-.6 1.7-.5 2.3.1l2.3 2.3c.7.7.7 1.8 0 2.5l-1.2 1.2c-.9.9-2.2 1.2-3.4.8-5.2-1.8-9.3-5.9-11.1-11.1-.4-1.2-.1-2.5.8-3.4l1.2-1.2c.7-.7 1.8-.7 2.5 0z"
          fill="currentColor"
        />
      </svg>
      <span class="tel-chip-num">{telBonito}</span>
      <span class="tel-chip-corto">Llamar</span>
    </a>
  </header>

  <main id="inicio">
    <!-- ═══════════ HERO ═══════════ -->
    <section class="hero">
      <div class="hero-texto">
        <p class="hero-kicker">
          <span class="hero-kicker-punto" aria-hidden="true"></span>
          Clínica dental en {lead.ciudad}
        </p>
        <h1>{lead.negocio}</h1>
        <p class="hero-sub">
          Implantes, ortodoncia invisible y estética dental con un equipo que te
          llama por tu nombre. La sonrisa de {lead.ciudad}, en buenas manos.
        </p>
        <div class="hero-cta">
          <a class="btn-coral" href={telHref}>
            <span>Pide tu primera visita</span>
            <strong>{telBonito}</strong>
          </a>
          <a class="btn-fantasma" href="#tratamientos">Ver tratamientos</a>
        </div>
        <ul class="hero-badges" role="list">
          <li>Primera visita y radiografía <b>gratis</b></li>
          <li>Urgencias <b>en el día</b></li>
          <li>Financiación <b>sin intereses</b></li>
        </ul>
      </div>

      <div class="hero-visual">
        <div class="arcada-sombra" aria-hidden="true"></div>
        <figure class="arcada">
          {
            lead.foto ? (
              <img
                src={lead.foto}
                alt={`Interior de ${lead.negocio}, en ${lead.ciudad}`}
                width="900"
                height="1200"
                fetchpriority="high"
              />
            ) : (
              <div class="ilustracion" role="img" aria-label="Ilustración de una consulta dental">
                <svg viewBox="0 0 480 640" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
                  <defs>
                    <linearGradient id="fondo-menta" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0" stop-color="#dcefe3" />
                      <stop offset="1" stop-color="#b8dcc6" />
                    </linearGradient>
                    <linearGradient id="brillo-diente" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0" stop-color="#ffffff" />
                      <stop offset="1" stop-color="#eef4ee" />
                    </linearGradient>
                  </defs>
                  <rect width="480" height="640" fill="url(#fondo-menta)"></rect>
                  <g stroke="#10352c" stroke-opacity=".14" stroke-width="2" fill="none">
                    <circle cx="240" cy="330" r="205"></circle>
                    <circle cx="240" cy="330" r="150" stroke-dasharray="3 9"></circle>
                  </g>
                  <g stroke="#10352c" stroke-width="7" stroke-linecap="round" fill="none" opacity=".82">
                    <line x1="368" y1="568" x2="152" y2="428"></line>
                    <circle cx="128" cy="412" r="30" fill="#fbfaf7"></circle>
                  </g>
                  <g stroke="#10352c" stroke-width="7" stroke-linecap="round" fill="none" opacity=".82">
                    <line x1="112" y1="568" x2="338" y2="446"></line>
                    <path d="M338 446q28-16 22-44" stroke-width="6"></path>
                  </g>
                  <g>
                    <ellipse cx="240" cy="520" rx="118" ry="20" fill="#10352c" opacity=".12"></ellipse>
                    <path
                      d="M240 170c-62 0-93 40-85 97 4.5 33 20 62 27.5 102 4 24.5 17 39.5 29.5 39.5 14.5 0 16.5-24.5 20-45.5 3-18.5 13-18.5 16 0 3.5 21 5.5 45.5 20 45.5 12.5 0 25.5-15 29.5-39.5 7.5-40 23-69 27.5-102 8-57-23-97-85-97z"
                      fill="url(#brillo-diente)"
                      stroke="#10352c"
                      stroke-width="7"
                      stroke-linejoin="round"
                    ></path>
                    <path d="M196 262q44 26 88 0" stroke="#10352c" stroke-width="6" stroke-linecap="round" fill="none" opacity=".55"></path>
                  </g>
                  <g fill="#ff6952">
                    <path d="M340 150l7 18 18 7-18 7-7 18-7-18-18-7 18-7z"></path>
                    <path d="M128 208l5 12 12 5-12 5-5 12-5-12-12-5 12-5z" opacity=".85"></path>
                    <circle cx="356" cy="252" r="6" opacity=".7"></circle>
                  </g>
                </svg>
              </div>
            )
          }
        </figure>
        <div class="chip-flotante" aria-hidden="true">
          <span class="chip-estrella">★</span>
          <span><b>4,9</b> · 212 reseñas</span>
        </div>
      </div>
    </section>

    <!-- hilo dental nº1 -->
    <div class="hilo" aria-hidden="true">
      <svg viewBox="0 0 1200 90" preserveAspectRatio="xMidYMid meet">
        <path
          pathLength="1"
          d="M-20 52 C 170 18 330 76 500 48 C 552 40 566 20 594 20 C 622 20 632 42 613 54 C 596 64 574 55 583 39 C 594 20 650 26 716 38 C 880 66 1030 20 1220 44"
        ></path>
      </svg>
    </div>

    <!-- ═══════════ CIFRAS ═══════════ -->
    <section class="cifras" aria-label="La clínica en cifras">
      <div class="cifra" data-reveal>
        <p class="cifra-num"><span data-count="15" data-prefijo="+">0</span> años</p>
        <p class="cifra-pie">cuidando bocas de {lead.ciudad} y alrededores</p>
      </div>
      <div class="cifra" data-reveal style="--d:.12s">
        <p class="cifra-num"><span data-count="9400" data-miles>0</span> sonrisas</p>
        <p class="cifra-pie">tratadas de principio a fin en nuestra consulta</p>
      </div>
      <div class="cifra" data-reveal style="--d:.24s">
        <p class="cifra-num"><span data-count="97" data-sufijo="%">0</span></p>
        <p class="cifra-pie">de nuestros pacientes nos recomiendan a los suyos</p>
      </div>
    </section>

    <!-- ═══════════ TRATAMIENTOS ═══════════ -->
    <section class="tratamientos" id="tratamientos">
      <header class="seccion-cabecera" data-reveal>
        <h2>Todo lo que tu boca puede necesitar</h2>
        <p>De la limpieza anual al implante más complejo, sin salir de {lead.ciudad}.</p>
      </header>

      <div class="bento">
        <article class="tile tile-implantes" data-reveal>
          <svg class="tile-icono" viewBox="0 0 48 48" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M24 5c-7.5 0-11 4.4-10.2 10.6.4 3.1 1.6 5.4 2.6 8.4h15.2c1-3 2.2-5.3 2.6-8.4C35 9.4 31.5 5 24 5z"></path>
              <path d="M19 28h10M18.5 33h11M20 38h8M21.5 43h5"></path>
            </g>
          </svg>
          <h3>Implantología</h3>
          <p>
            Vuelve a masticar —y a reír— con confianza. Cirugía guiada en 3D y
            carga inmediata en casos seleccionados.
          </p>
          <span class="tile-flecha" aria-hidden="true">→</span>
        </article>

        <article class="tile tile-menta" data-reveal style="--d:.08s">
          <svg class="tile-icono" viewBox="0 0 48 48" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 30c0-10 7-19 16-19s16 9 16 19"></path>
              <path d="M11 30c0-8 5.5-15 13-15s13 7 13 15" stroke-dasharray="1 5"></path>
              <path d="M8 30q8 6 16 6t16-6"></path>
            </g>
          </svg>
          <h3>Ortodoncia invisible</h3>
          <p>Alineadores transparentes que nadie nota. Revisión cada 6–8 semanas.</p>
          <span class="tile-flecha" aria-hidden="true">→</span>
        </article>

        <article class="tile tile-borde" data-reveal style="--d:.16s">
          <svg class="tile-icono" viewBox="0 0 48 48" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10c-6.6 0-9.9 4.3-9 10.4.5 3.6 2.1 6.6 2.9 11 .4 2.6 1.8 4.2 3.1 4.2 1.5 0 1.8-2.6 2.1-4.8.3-2 1.5-2 1.8 0 .4 2.2.7 4.8 2.2 4.8 1.3 0 2.7-1.6 3.1-4.2.8-4.4 2.4-7.4 2.9-11C32 14.3 28.6 10 22 10z"></path>
              <path d="M37 6l1.8 4.2L43 12l-4.2 1.8L37 18l-1.8-4.2L31 12l4.2-1.8zM40 24l1 2.4 2.4 1-2.4 1-1 2.4-1-2.4-2.4-1 2.4-1z" fill="currentColor" stroke="none"></path>
            </g>
          </svg>
          <h3>Estética y blanqueamiento</h3>
          <p>Carillas y blanqueamiento LED: una sonrisa lista para fotos.</p>
          <span class="tile-flecha" aria-hidden="true">→</span>
        </article>

        <article class="tile tile-coral" data-reveal style="--d:.1s">
          <svg class="tile-icono" viewBox="0 0 48 48" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M24 9c-6.6 0-9.9 4.3-9 10.4.5 3.6 2.1 6.6 2.9 11 .4 2.6 1.8 4.2 3.1 4.2 1.5 0 1.8-2.6 2.1-4.8.3-2 1.5-2 1.8 0 .4 2.2.7 4.8 2.2 4.8 1.3 0 2.7-1.6 3.1-4.2.8-4.4 2.4-7.4 2.9-11C34 13.3 30.6 9 24 9z"></path>
              <path d="M20 22c1.2-1.6 3-1.6 4 0 1-1.6 2.8-1.6 4 0 .9 1.3.2 3-4 5.6-4.2-2.6-4.9-4.3-4-5.6z" fill="currentColor" stroke="none"></path>
            </g>
          </svg>
          <h3>Odontopediatría</h3>
          <p>Primeras visitas sin miedo: los peques salen pidiendo volver.</p>
          <span class="tile-flecha" aria-hidden="true">→</span>
        </article>

        <article class="tile tile-borde" data-reveal style="--d:.18s">
          <svg class="tile-icono" viewBox="0 0 48 48" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M24 7c-6.6 0-9.9 4.3-9 10.4.4 3 1.5 5.6 2.3 8.6h13.4c.8-3 1.9-5.6 2.3-8.6C34 11.3 30.6 7 24 7z"></path>
              <path d="M7 33q4-5 8 0t8 0 8 0 8 0"></path>
              <path d="M7 40q4-5 8 0t8 0 8 0 8 0" opacity=".5"></path>
            </g>
          </svg>
          <h3>Encías (periodoncia)</h3>
          <p>Sangrado, retracción o mal aliento: lo frenamos a tiempo.</p>
          <span class="tile-flecha" aria-hidden="true">→</span>
        </article>

        <article class="tile tile-menta tile-higiene" data-reveal style="--d:.22s">
          <svg class="tile-icono" viewBox="0 0 48 48" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 40 34 16"></path>
              <path d="M31 13l6 6M34 10l6 6M37 7l6 6"></path>
              <path d="M8 42q-2-4 2-6"></path>
            </g>
          </svg>
          <h3>Higiene y prevención</h3>
          <p>Limpieza anual y revisión: la visita que te ahorra todas las demás.</p>
          <span class="tile-flecha" aria-hidden="true">→</span>
        </article>

        <article class="tile tile-urgencias" data-reveal style="--d:.12s">
          <svg class="tile-icono" viewBox="0 0 48 48" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 8c-6.6 0-9.9 4.3-9 10.4.5 3.6 2.1 6.6 2.9 11 .4 2.6 1.8 4.2 3.1 4.2 1.5 0 1.8-2.6 2.1-4.8.3-2 1.5-2 1.8 0 .4 2.2.7 4.8 2.2 4.8 1.3 0 2.7-1.6 3.1-4.2.8-4.4 2.4-7.4 2.9-11C30 12.3 26.6 8 20 8z"></path>
              <path d="M36 4l-5 11h6l-7 13 2-9h-6l4-15z" fill="currentColor" stroke="none"></path>
            </g>
          </svg>
          <div>
            <h3>Urgencias en el día</h3>
            <p>¿Dolor agudo, rotura, inflamación? Te hacemos hueco hoy.</p>
          </div>
          <a class="tile-tel" href={telHref}>{telBonito}</a>
        </article>
      </div>
    </section>

    <!-- hilo dental nº2 (invertido) -->
    <div class="hilo hilo-invertido" aria-hidden="true">
      <svg viewBox="0 0 1200 90" preserveAspectRatio="xMidYMid meet">
        <path
          pathLength="1"
          d="M-20 52 C 170 18 330 76 500 48 C 552 40 566 20 594 20 C 622 20 632 42 613 54 C 596 64 574 55 583 39 C 594 20 650 26 716 38 C 880 66 1030 20 1220 44"
        ></path>
      </svg>
    </div>

    <!-- ═══════════ POR QUÉ ═══════════ -->
    <section class="porque">
      <h2 data-reveal>Por qué {lead.ciudad} confía en nosotros</h2>
      <ol class="porque-lista" role="list">
        <li data-reveal>
          <h3>Verás tu boca en pantalla</h3>
          <p>
            Escáner intraoral 3D en la primera visita: entiendes cada decisión
            antes de tomarla. Y sin moldes incómodos.
          </p>
        </li>
        <li data-reveal style="--d:.08s">
          <h3>Presupuesto cerrado, por escrito</h3>
          <p>
            Lo que firmamos es lo que pagas. Ni sorpresas en la última visita ni
            letra pequeña.
          </p>
        </li>
        <li data-reveal style="--d:.16s">
          <h3>El mismo doctor, de principio a fin</h3>
          <p>
            Nada de empezar tu tratamiento con una persona y terminarlo con
            otra. Aquí tu caso tiene nombre y apellidos.
          </p>
        </li>
        <li data-reveal style="--d:.24s">
          <h3>Pagas a tu ritmo</h3>
          <p>
            Financiación hasta 24 meses sin intereses. Tu salud no debería
            esperar a fin de mes.
          </p>
        </li>
      </ol>
    </section>

    <!-- ═══════════ PRIMERA VISITA ═══════════ -->
    <section class="visita">
      <header class="seccion-cabecera" data-reveal>
        <h2>Tu primera visita, paso a paso</h2>
        <p>Sin compromiso, sin coste y sin letra pequeña.</p>
      </header>
      <ol class="pasos" role="list">
        <li class="paso">
          <span class="paso-num" aria-hidden="true">1</span>
          <div>
            <h3>Llama y te damos hora</h3>
            <p>
              Teléfono o WhatsApp al <a href={telHref}>{telBonito}</a>. Hueco en
              menos de 24 horas.
            </p>
          </div>
        </li>
        <li class="paso">
          <span class="paso-num" aria-hidden="true">2</span>
          <div>
            <h3>Revisión completa gratis</h3>
            <p>
              Exploración, escáner 3D y radiografía panorámica sin coste. Sales
              sabiendo exactamente cómo está tu boca.
            </p>
          </div>
        </li>
        <li class="paso">
          <span class="paso-num" aria-hidden="true">3</span>
          <div>
            <h3>Plan claro y a tu ritmo</h3>
            <p>
              Presupuesto cerrado, prioridades explicadas y financiación si la
              necesitas. Tú decides cuándo empezamos.
            </p>
          </div>
        </li>
      </ol>
    </section>

    <!-- ═══════════ CIERRE ═══════════ -->
    <section class="cierre" data-reveal>
      <svg class="cierre-molar" viewBox="0 0 48 48" aria-hidden="true">
        <path
          d="M24 4c-9.4 0-14.1 6.2-12.9 14.8.7 5 3 9.4 4.1 15.6.6 3.7 2.6 6 4.5 6 2.1 0 2.5-3.7 3-6.9.5-2.8 2.1-2.8 2.6 0 .5 3.2.9 6.9 3 6.9 1.9 0 3.9-2.3 4.5-6 1.1-6.2 3.4-10.6 4.1-15.6C38.1 10.2 33.4 4 24 4z"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
        ></path>
      </svg>
      <h2>¿Hablamos de tu sonrisa?</h2>
      <p class="cierre-sub">
        Primera visita y radiografía gratis. Te atendemos hoy mismo en {lead.ciudad}.
      </p>
      <a class="cierre-tel" href={telHref}>{telBonito}</a>
      <p class="cierre-horario">Lunes a viernes · 9:00 – 20:00</p>
    </section>
  </main>

  <footer class="pie">
    <p class="pie-marca">{lead.negocio}</p>
    <p>{lead.ciudad} · <a href={telHref}>{telBonito}</a></p>
  </footer>

  <noscript>
    <style>
      [data-reveal] { opacity: 1 !important; transform: none !important; }
      .hilo path { stroke-dashoffset: 0 !important; }
    </style>
  </noscript>
</Layout>

<style>
  /* ───────── topbar ───────── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem clamp(1rem, 4vw, 2.5rem);
    background: color-mix(in srgb, var(--esmalte) 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition: box-shadow 0.4s ease;
  }
  .topbar.compacta {
    box-shadow: 0 1px 0 var(--menta-borde), 0 10px 30px -18px rgb(16 53 44 / 0.35);
  }
  .marca {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1rem, 2.6vw, 1.15rem);
    color: var(--pino);
    text-decoration: none;
    letter-spacing: -0.01em;
    min-width: 0;
  }
  .marca span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .marca-diente {
    width: 1.9rem;
    height: 1.9rem;
    flex: none;
    color: var(--pino);
  }
  .marca-chispa {
    fill: var(--coral);
  }
  .tel-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.05rem;
    border-radius: 999px;
    background: var(--pino);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.25s var(--ease-spring), background 0.25s ease;
  }
  .tel-chip:hover { background: var(--pino-2); transform: translateY(-2px); }
  .tel-chip:active { transform: scale(0.97); }
  .tel-chip svg { width: 1rem; height: 1rem; }
  .tel-chip-corto { display: none; }
  @media (max-width: 560px) {
    .tel-chip-num { display: none; }
    .tel-chip-corto { display: inline; }
  }

  /* ───────── hero ───────── */
  .hero {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 4rem) clamp(1.25rem, 4vw, 2.5rem) clamp(2.5rem, 5vw, 4.5rem);
  }
  @media (min-width: 880px) {
    .hero { grid-template-columns: 1.05fr 0.95fr; min-height: min(88vh, 46rem); }
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pino-2);
    animation: sube 0.9s var(--ease-out-soft) 0.05s both;
  }
  .hero-kicker-punto {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--coral);
    animation: late 2.4s ease-in-out infinite;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7.5vw, 4.4rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 800;
